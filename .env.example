KEYPAIR_FILE="keypair.json"
RPC="https://api.mainnet-beta.solana.com"

# Telegram Bot Configuration
# 取得 Bot Token: 在 Telegram 中與 @BotFather 對話，建立新的 bot
# 取得 Chat ID: 在 Telegram 中與你的 bot 對話後，訪問 https://api.telegram.org/bot<YOUR_BOT_TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
TELEGRAM_NOTIFY_ENABLED=true

# Strategy Runtime (Anchor) — Week 3
# When STRATEGY_RUNTIME_PROGRAM_ID is set the backend automatically uses the
# AnchorOnchainAdapter; when unset (default) it falls back to the Noop adapter.
STRATEGY_RUNTIME_PROGRAM_ID=
# Keeper signer for commit_state / set_lifecycle_status / close_deployment.
# Accepts either a base58 secret key OR a JSON array of 64 bytes
# (e.g. the contents of a solana-keygen JSON file).
STRATEGY_RUNTIME_KEEPER_SECRET=
SOLANA_RPC_URL=https://api.devnet.solana.com
STRATEGY_RUNTIME_COMMITMENT=confirmed

# MagicBlock Ephemeral Rollups — Week 4
# When MAGICBLOCK_ROUTER_URL is set the backend wires the real ER adapter,
# which forwards transactions through Magic Router and records the resulting
# signatures on the deployment row. When unset, the Noop adapter is used.
MAGICBLOCK_ROUTER_URL=
# Optional direct ER RPC endpoint, used by bots that need to query rollup-only
# state. The router endpoint above is sufficient for transaction routing.
MAGICBLOCK_ER_RPC_URL=
# Pubkey of MagicBlock's delegation program. Reserved for future
# server-side ix construction; currently optional.
MAGICBLOCK_DELEGATE_PROGRAM_ID=
# Commitment level used for both router and ER connections (default: confirmed).
MAGICBLOCK_COMMITMENT=confirmed

# Umbra (Encrypted User Account) — Week 4 (v2 SDK rewrite)
# When UMBRA_ENABLED=true the backend wires UmbraRealAdapter backed by
# @umbra-privacy/sdk. The platform keeper keypair (STRATEGY_RUNTIME_KEEPER_SECRET)
# acts as the Umbra signer — master seed is derived from a wallet-signed
# consent message (KMAC256). No static UMBRA_MASTER_SEED is needed.
UMBRA_ENABLED=
# Network to connect to: mainnet (default), devnet, or localnet.
UMBRA_NETWORK=mainnet
# Optional override for the UTXO indexer endpoint.
# UMBRA_INDEXER_API_ENDPOINT=https://utxo-indexer.api.umbraprivacy.com

# MagicBlock PER (Private Ephemeral Rollups) — Week 5
# When MAGICBLOCK_PER_ENDPOINT is set the backend wires the real PER adapter.
# The adapter proxies auth challenges to the TEE endpoint (/auth/challenge
# and /auth/login) so that tokens are issued by the TEE, not by the backend.
# Postgres is used only for token bookkeeping (audit + PerAuthGuard).
MAGICBLOCK_PER_ENDPOINT=
MAGICBLOCK_PER_API_KEY=
# Auth token TTLs (minutes); see backend/docs/STRATEGY_PLATFORM_DEV_SPEC.md.
PER_CHALLENGE_TTL_MIN=5
PER_AUTH_TOKEN_TTL_MIN=30

# MagicBlock Private Payments API — Week 5
# When MAGICBLOCK_PP_ENDPOINT is set the backend wires the real Private
# Payments adapter; otherwise Noop. The optional API key is forwarded as a
# Bearer token on every request.
MAGICBLOCK_PP_ENDPOINT=
MAGICBLOCK_PP_API_KEY=

# Cross-cutting hardening — Week 6
# Set to "json" to emit JSON-line structured logs (use in production / k8s).
# Anything else (including unset) keeps the default colored console logger.
LOG_FORMAT=
# When NODE_ENV=production but a critical adapter (onchain/er/per/pp/umbra)
# is still in noop mode, the platform refuses to boot unless this is "true".
# Useful for staging/canary where some integrations are not yet live.
STRATEGY_ALLOW_NOOP_IN_PROD=
# Optional: enable strategy platform e2e suite (test/strategy-platform.e2e-spec.ts).
# When unset the suite skips, so CI without a Supabase test DB stays green.
STRATEGY_E2E=
