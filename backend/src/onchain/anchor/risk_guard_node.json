    "description": "On-chain drawdown guard node for the strategy_runtime workflow ecosystem"
  },
  "instructions": [
    {
      "name": "check_drawdown",
      "docs": [
        "Submit a current drawdown reading. If it exceeds `max_allowed_bps`,",
        "the guard freezes and all subsequent calls fail until `reset_guard`."
      ],
      "discriminator": [
        80,
        116,
        81,
        5,
        102,
        81,
        95,
        138
      ],
      "accounts": [
        {
          "name": "caller",
          "docs": [
            "Anyone can submit a drawdown reading — the guard is keyed by creator",
            "and we trust whoever signs to be reporting on the right strategy."
          ],
          "signer": true
        },
        {
          "name": "guard",
          "writable": true
        }
      ],
      "args": [
        {
          "name": "current_drawdown_bps",
          "type": "u16"
        }
      ]
    },
    {
      "name": "initialize_guard",
      "docs": [
        "Initialize a per-creator drawdown guard.",
        "`max_allowed_bps` is the threshold beyond which the guard freezes."
      ],
      "discriminator": [
        63,
        189,
        246,
        157,
        77,
        125,
        157,
        142
      ],
      "accounts": [
        {
          "name": "creator",
          "writable": true,
          "signer": true
        },
        {
          "name": "guard",
          "writable": true,
          "pda": {
            "seeds": [
              {
                "kind": "const",
                "value": [
                  114,
                  105,
                  115,
                  107,
                  95,
                  103,
                  117,
                  97,
                  114,
                  100
                ]
              },
              {
                "kind": "account",
                "path": "creator"
              }
            ]
          }
        },
        {
          "name": "system_program",
          "address": "11111111111111111111111111111111"
        }
      ],
      "args": [
        {
          "name": "max_allowed_bps",
          "type": "u16"
        }
      ]
    },
    {
      "name": "reset_guard",
      "docs": [
        "Creator-only — clear the frozen flag."
