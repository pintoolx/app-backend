        139,
        2,
        183,
        99
      ],
      "accounts": [
        {
          "name": "creator",
          "signer": true,
          "relations": [
            "guard"
          ]
        },
        {
          "name": "guard",
          "writable": true
        }
      ],
      "args": []
    }
  ],
  "accounts": [
    {
      "name": "GuardState",
      "discriminator": [
        23,
        232,
        95,
        177,
        15,
        220,
        133,
        0
      ]
    }
  ],
  "errors": [
    {
      "code": 6000,
      "name": "GuardFrozen",
      "msg": "Guard is frozen — reset it before reuse"
    },
    {
      "code": 6001,
      "name": "InvalidMaxBps",
      "msg": "max_allowed_bps must be greater than 0 and at most 10000"
    },
    {
      "code": 6002,
      "name": "UnauthorizedCaller",
      "msg": "Caller is not the creator of this guard"
    }
  ],
  "types": [
    {
      "name": "GuardState",
      "docs": [
        "Per-creator drawdown guard. One PDA per (program, creator).",
        "",
        "`frozen` flips to true the first time `check_drawdown` observes a value",
        "exceeding `max_allowed_bps`. While frozen, all subsequent",
        "`check_drawdown` calls fail until `reset_guard` is invoked by the",
        "`creator`."
      ],
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "creator",
            "type": "pubkey"
          },
          {
            "name": "max_allowed_bps",
            "type": "u16"
          },
          {
            "name": "last_drawdown_bps",
            "type": "u16"
          },
          {
            "name": "frozen",
            "type": "bool"
          },
          {
            "name": "bump",
            "type": "u8"
          },
          {
            "name": "_reserved",
            "docs": [
              "Reserved for future fields without re-deriving accounts."
            ],
            "type": {
              "array": [
                "u8",
                24
              ]
            }
          }
        ]
      }
    }
  ]
