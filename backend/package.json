{
  "name": "pintool-backend",
  "version": "1.0.0",
  "description": "PinTool Web3 Workflow Automation Backend",
  "author": "PinTool",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "docs:nodes": "ts-node -P tsconfig.json scripts/generate-node-docs.ts",
    "idl:sync": "ts-node -P tsconfig.json scripts/sync-idl.ts sync",
    "idl:check": "ts-node -P tsconfig.json scripts/sync-idl.ts check",
    "admin:create": "ts-node -P tsconfig.json scripts/admin/create-admin.ts create",
    "admin:reset-totp": "ts-node -P tsconfig.json scripts/admin/create-admin.ts reset-totp",
    "admin:reset-password": "ts-node -P tsconfig.json scripts/admin/create-admin.ts reset-password",
    "admin:list": "ts-node -P tsconfig.json scripts/admin/create-admin.ts list",
    "admin:disable": "ts-node -P tsconfig.json scripts/admin/create-admin.ts disable",
    "admin:enable": "ts-node -P tsconfig.json scripts/admin/create-admin.ts enable",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInWorker",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:e2e:strategy": "STRATEGY_E2E=1 jest --config ./test/jest-e2e.json --testPathPattern=strategy-platform"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.48",
    "@anchor-lang/core": "^1.0.1",
    "@crossmint/wallets-sdk": "^0.21.0",
    "@jup-ag/api": "^6.0.45",
    "@kamino-finance/klend-sdk": "^7.1.9",
    "@magicblock-labs/ephemeral-rollups-sdk": "^0.12.0",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/swagger": "^7.0.0",
    "@nestjs/throttler": "^6.5.0",
    "@pythnetwork/hermes-client": "^2.0.0",
    "@solana-program/address-lookup-table": "^0.10.0",
    "@solana-program/compute-budget": "^0.11.0",
    "@solana/kit": "^5.0.0",
    "@solana/rpc-types": "^4.0.0",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.95.8",
    "@supabase/supabase-js": "^2.76.1",
    "@umbra-privacy/sdk": "^4.0.0",
    "@umbra-privacy/web-zk-prover": "^2.0.1",
    "ai": "^6.0.141",
    "axios": "^1.13.4",
    "bcryptjs": "^3.0.3",
    "bs58": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "decimal.js": "^10.6.0",
    "dotenv": "^17.2.3",
    "helmet": "^8.1.0",
    "jose": "^6.2.2",
    "otplib": "^13.4.0",
    "pg": "^8.17.2",
    "prom-client": "^15.1.3",
    "prompts": "^2.4.2",
    "qrcode-terminal": "^0.12.0",
    "referral-codes": "^3.0.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "solana-agent-kit": "^2.0.10",
    "tweetnacl": "^1.0.3",
    "typescript-telegram-bot-api": "^0.10.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.2",
    "@types/node": "^20.3.1",
    "@types/pg": "^8.16.0",
    "@types/prompts": "^2.4.9",
    "@types/qrcode-terminal": "^0.12.2",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.42.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.3",
    "webpack": "^5.104.1"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
