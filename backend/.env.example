# ============================================
# PinTool Backend - Environment Variables
# ============================================
# Copy this file to .env and fill in the values

# ============================================
# Server Configuration
# ============================================
PORT=3000
NODE_ENV=development
# CORS allowed origins (comma-separated). Use * for all origins (development only).
CORS_ORIGIN=*

# ============================================
# Supabase (Required)
# ============================================
# Bearer-protected APIs expect Supabase access tokens.
# Set issuer/audience if your project differs from the defaults.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key
JWT_SECRET=your-supabase-jwt-secret
SUPABASE_JWT_ISSUER=
SUPABASE_JWT_AUDIENCE=authenticated

# ============================================
# Solana RPC (Required)
# ============================================
# Recommended: Use a paid RPC provider for production
# Free options: https://api.mainnet-beta.solana.com (rate limited)
# Paid options: Helius, QuickNode, Alchemy, Triton
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_WS_URL=wss://api.mainnet-beta.solana.com

# ============================================
# Strategy Runtime / Onchain Adapter (Required for strategy execution)
# ============================================
# Program ID of the deployed Anchor strategy program
STRATEGY_RUNTIME_PROGRAM_ID=
# Base58-encoded secret key (or JSON byte array) for the keeper keypair.
# Used by both the onchain adapter (sign + send strategy txs) and the Umbra
# real adapter (deployment signer / KMAC256 derivation).
STRATEGY_RUNTIME_KEEPER_SECRET=
# Commitment level for onchain transactions: processed, confirmed, finalized
STRATEGY_RUNTIME_COMMITMENT=confirmed
# Keeper polling interval in milliseconds (default: 30000)
STRATEGY_KEEPER_POLLING_MS=30000
# Allow noop adapters in production (set false for production deployments)
STRATEGY_ALLOW_NOOP_IN_PROD=true

# ============================================
# Crossmint Custodial Wallet (Required)
# ============================================
# Get your API key from: https://www.crossmint.com/console
# Use staging key for development, production key for mainnet
CROSSMINT_SERVER_API_KEY=sk_staging_xxx
# Server key signer secret — generate with: echo "xmsk1_$(openssl rand -hex 32)"
CROSSMINT_SIGNER_SECRET=xmsk1_YOUR_64_HEX_CHAR_SECRET
CROSSMINT_ENVIRONMENT=staging
# Options: staging, production

# ============================================
# MagicBlock Ephemeral Rollups (Optional)
# ============================================
# ER Router URL for committing state to ephemeral rollups
MAGICBLOCK_ROUTER_URL=
# ER RPC URL for executing transactions on ER
MAGICBLOCK_ER_RPC_URL=
# MagicBlock delegate program ID
MAGICBLOCK_DELEGATE_PROGRAM_ID=
# Commitment level for MagicBlock transactions
MAGICBLOCK_COMMITMENT=confirmed

# ============================================
# MagicBlock Private Ephemeral Rollups (PER) — Optional
# ============================================
# PER uses a TEE (Trusted Execution Environment) for private state.
# The endpoint requires an auth token obtained via challenge/verify flow.
#
# Devnet:  https://devnet-tee.magicblock.app
# Mainnet: https://mainnet-tee.magicblock.app
#
# When set, the backend wires MagicBlockPerRealAdapter.
# When unset, MagicBlockPerNoopAdapter is used (safe fallback).
MAGICBLOCK_PER_ENDPOINT=
MAGICBLOCK_PER_API_KEY=
# Challenge TTL in minutes for PER auth tokens
PER_CHALLENGE_TTL_MIN=5

# ============================================
# MagicBlock Private Payments (PP) — Optional
# ============================================
MAGICBLOCK_PP_ENDPOINT=
MAGICBLOCK_PP_API_KEY=

# ============================================
# Umbra Privacy Protocol (optional)
# ============================================
# When UMBRA_ENABLED=true the backend wires UmbraRealAdapter backed by
# @umbra-privacy/sdk. The platform keeper keypair (STRATEGY_RUNTIME_KEEPER_SECRET)
# is used as the Umbra signer.
# Requires: STRATEGY_RUNTIME_KEEPER_SECRET to be configured.
UMBRA_ENABLED=
# Network: mainnet (default), devnet, or localnet
UMBRA_NETWORK=mainnet
# Optional: override default UTXO indexer endpoint
# UMBRA_INDEXER_API_ENDPOINT=https://utxo-indexer.api.umbraprivacy.com
UMBRA_INDEXER_API_ENDPOINT=
UMBRA_RELAYER_ENDPOINT=
UMBRA_TRANSFER_ENABLED=false

# ============================================
# Admin Panel (Required for admin access)
# ============================================
# JWT secret for admin authentication (generate a random hex string)
ADMIN_JWT_SECRET=your-admin-jwt-secret
# TOTP encryption key for 2FA (64 hex characters)
ADMIN_TOTP_ENC_KEY=
ADMIN_TOTP_ISSUER=PinTool Admin
# Token TTLs (defaults shown)
ADMIN_ACCESS_TOKEN_TTL=15m
ADMIN_TEMP_TOKEN_TTL=5m
ADMIN_REFRESH_TOKEN_TTL=7d
# IP allowlist (comma-separated CIDRs, empty = allow all)
ADMIN_IP_ALLOWLIST=
# Brute force protection
ADMIN_MAX_FAILED_LOGINS=5
ADMIN_LOCKOUT_MINUTES=15

# ============================================
# Telegram Notifications (Optional)
# ============================================
# Create a bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_NOTIFY_ENABLED=false
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_SECRET=

# ============================================
# Pyth Price Feeds (Optional)
# ============================================
# Default endpoint works without API key
PYTH_HERMES_ENDPOINT=https://hermes.pyth.network

# ============================================
# Helius API (Optional)
# ============================================
# Required for: HeliusWebhookNode
# Get your API key from: https://www.helius.dev/
# Free tier: 100k credits/month
HELIUS_API_KEY=

# ============================================
# Lulo Lending API (Optional)
# ============================================
# Required for: LuloNode
# Get your API key from: https://docs.lulo.fi/ (Developer Dashboard)
LULO_API_KEY=

# ============================================
# Sanctum LST API (Optional)
# ============================================
# Required for: SanctumNode
# Get your API key from: https://learn.sanctum.so/docs/for-developers/sanctum-api
SANCTUM_API_KEY=

# ============================================
# NVIDIA AI API (Optional)
# ============================================
# Required for: AI-powered features (workflow builder assistant)
# Get your API key from: https://build.nvidia.com/
NVIDIA_API_KEY=nvapi-xxx
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=deepseek-ai/deepseek-v3.2

# ============================================
# Node API Key Requirements Summary
# ============================================
# 
# No API Key Required:
#   - SwapNode (Jupiter)
#   - LimitOrderNode (Jupiter)
#   - StakeNode (Jupiter)
#   - KaminoNode (On-chain)
#   - DriftNode (Wallet auth)
#   - PriceFeedNode (Pyth)
#   - TransferNode (Native)
#   - BalanceNode (RPC)
#
# API Key Required:
#   - HeliusWebhookNode -> HELIUS_API_KEY
#   - LuloNode -> LULO_API_KEY
#   - SanctumNode -> SANCTUM_API_KEY
