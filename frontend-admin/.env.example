# URL of the Nest backend reachable from this Next.js process.
ADMIN_BACKEND_URL=http://localhost:3000

# MUST exactly match the backend's ADMIN_JWT_SECRET. Used by Server Components
# to verify the signed admin_access cookie before rendering protected pages.
ADMIN_JWT_SECRET=

# (optional) Set to "production" to flip __Host- cookie prefix on / off.
NODE_ENV=development
